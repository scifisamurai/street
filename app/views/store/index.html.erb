<div class="w-full">
  <%= notice %>

  <h1 class="font-bold text-xl mb-6 pb-2 border-b-2">
    <%= t('.title_html') %> <%= pluralize(session[:counter], 'visit') if session[:counter] > 5 %>
  </h1>

  <%# identify the channel we'll subscribe to (products here) %>
  <%= turbo_stream_from 'products' %>

  <ul>
    <% cache @products do %>
      <% @products.each do |product| %>
        <% cache product do %>
          <%= render partial: 'product', object: product %>
        <% end %>
      <% end %>
    <% end %>
  </ul>
</div>
